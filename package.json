{
  "name": "greatstorage",
  "version": "0.2.0",
  "description": "Gives localStorage superpowers. Handles serialization of rich types, key expiration, namespacing, and schema validation",
  "keywords": [
    "expiration",
    "localstorage",
    "serialization",
    "storage",
    "ttl"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "check": "pnpm format && pnpm lint && pnpm test",
    "build": "tsdown",
    "format": "oxfmt",
    "lint": "oxlint",
    "tc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "devalue": "^5"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3"
}
