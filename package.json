{
  "name": "greatstorage",
  "version": "0.1.0",
  "description": "A Storage wrapper with automatic serialization and TTL support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "localstorage",
    "storage",
    "ttl",
    "expiration",
    "serialization"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "devalue": "^5.6.3"
  }
}
